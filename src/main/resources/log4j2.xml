<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <Appenders>
        <!-- Console appender: prints to stdout with timestamp, thread, level, logger, and message -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
        </Console>
    </Appenders>

    <Loggers>
        <!-- Application root logger at INFO — change to DEBUG for verbose output -->
        <Root level="INFO">
            <AppenderRef ref="Console"/>
        </Root>

        <!-- Suppress jPOS internal noise unless debugging the packager -->
        <Logger name="org.jpos" level="WARN" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>
    </Loggers>

</Configuration>
